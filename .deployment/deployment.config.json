{
  "app_name": "ai-reposcan",
  "version": "2.0.0",
  "deployment_type": "production",
  
  "urls": {
    "production": "https://scanllm.ai",
    "backend_default": "https://ai-reposcan.emergent.host",
    "preview": "https://aireposcan.preview.emergentagent.com"
  },
  
  "environment_variables": {
    "frontend": {
      "required": [
        {
          "name": "REACT_APP_BACKEND_URL",
          "description": "Backend API base URL",
          "production_value": "https://ai-reposcan.emergent.host",
          "preview_value": "https://aireposcan.preview.emergentagent.com",
          "validation": "Must NOT contain 'localhost' or 'preview' for production"
        },
        {
          "name": "WDS_SOCKET_PORT",
          "value": "443",
          "description": "WebSocket port for hot reload"
        }
      ],
      "optional": [
        {
          "name": "REACT_APP_ENABLE_VISUAL_EDITS",
          "value": "false"
        },
        {
          "name": "ENABLE_HEALTH_CHECK",
          "value": "false"
        }
      ]
    },
    "backend": {
      "required": [
        {
          "name": "EMERGENT_LLM_KEY",
          "description": "Universal LLM API key for AI explanations",
          "value": "sk-emergent-61fBe4fAe210f56D6C",
          "secret": true
        },
        {
          "name": "CORS_ORIGINS",
          "value": "*",
          "description": "Allowed CORS origins"
        }
      ],
      "optional": [
        {
          "name": "MONGO_URL",
          "value": "mongodb://localhost:27017",
          "description": "MongoDB URL (not used, app uses SQLite)"
        },
        {
          "name": "DB_NAME",
          "value": "test_database",
          "description": "Database name (not used, app uses SQLite)"
        }
      ]
    }
  },
  
  "build_steps": [
    {
      "step": "verify_environment",
      "command": "python3 /app/scripts/verify_env_config.py",
      "description": "Verify environment variables are set correctly"
    },
    {
      "step": "backend_install",
      "command": "cd /app/backend && pip install -r requirements.txt",
      "description": "Install Python dependencies"
    },
    {
      "step": "backend_db_init",
      "command": "cd /app/backend && python -c 'from core.database import init_db; init_db()'",
      "description": "Initialize SQLite database"
    },
    {
      "step": "frontend_install",
      "command": "cd /app/frontend && yarn install",
      "description": "Install Node dependencies"
    },
    {
      "step": "frontend_build",
      "command": "cd /app/frontend && yarn build",
      "description": "Build React production bundle",
      "note": "This bakes REACT_APP_BACKEND_URL into the bundle"
    }
  ],
  
  "post_deployment_tests": [
    {
      "name": "Frontend accessibility",
      "command": "curl -s -o /dev/null -w '%{http_code}' https://scanllm.ai",
      "expected": "200"
    },
    {
      "name": "Backend health",
      "command": "curl -s https://ai-reposcan.emergent.host/health | jq -r '.status'",
      "expected": "ok"
    },
    {
      "name": "Scan functionality",
      "command": "bash /app/scripts/deployment_verification.sh",
      "expected": "exit code 0"
    }
  ],
  
  "cache_busting": {
    "enabled": true,
    "strategy": "content_hash",
    "description": "React build automatically adds content hashes to filenames (main.[hash].js)"
  },
  
  "performance_targets": {
    "frontend_load_time": "< 3 seconds",
    "scan_time_small_repos": "< 5 seconds",
    "scan_time_medium_repos": "< 15 seconds",
    "api_response_time": "< 30 seconds"
  },
  
  "known_issues": [
    {
      "issue": "Frontend may use cached preview URL if not rebuilt",
      "solution": "Ensure REACT_APP_BACKEND_URL is set before 'yarn build'",
      "status": "resolved"
    },
    {
      "issue": "Git executable not in production container",
      "solution": "Git fallback to ZIP download implemented in git_utils.py",
      "status": "resolved"
    },
    {
      "issue": "Ownership mapping causes rate limiting",
      "solution": "Ownership mapping disabled for performance",
      "status": "resolved"
    }
  ]
}
